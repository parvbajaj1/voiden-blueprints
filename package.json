{
  "name": "@voiden/plugin-blueprints",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "description": "Save and reuse common API request structures as blueprints. Insert them anywhere with a slash command.",
  "main": "./src/plugin.ts",
  "scripts": {
    "build": "node build.mjs && node build-main.mjs",
    "build:main": "node build-main.mjs",
    "zip": "node zip.mjs",
    "release": "node build.mjs && node build-main.mjs && node generate-manifest.mjs"
  },
  "dependencies": {
    "@tiptap/pm": "^2.8.0",
    "@voiden/sdk": "^1.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  }
}
